<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:text="Linux v5.10.x-android // uptime: 12d, 4h, 23m"
        android:fontFamily="monospace"
        android:textColor="#161b22"
        android:textSize="8sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NetScan Pro"
            android:textColor="#D1D1D1"
            android:fontFamily="monospace"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="network diagnostic tool v1.0"
            android:textColor="#8b949e"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="32dp" />

        <TextView
            android:id="@+id/tvIpInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="detectando red..."
            android:textColor="#58a6ff"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingBottom="40dp" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="[ SUBNET SWEEP ]"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:backgroundTint="#161b22"
            android:textColor="#D1D1D1"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDiag"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="[ PING MONITOR ]"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:backgroundTint="#21262d"
            android:textColor="#58a6ff"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnHistorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ HISTORIAL ]"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#8b949e" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvCredits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="[ CREDITS ]"
        android:fontFamily="monospace"
        android:textColor="#21262d"
        android:textSize="11sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

</RelativeLayout>
