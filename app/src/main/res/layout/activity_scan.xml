<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NETSCAN // SUBNET SWEEP"
        android:textColor="#39d353"
        android:fontFamily="monospace"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tvIpInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="detectando..."
        android:textColor="#8b949e"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="[ SCAN ]"
            android:fontFamily="monospace"
            android:backgroundTint="#1a4d2e"
            android:textColor="#39d353" />

        <Button
            android:id="@+id/btnExport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="[ EXPORT ]"
            android:fontFamily="monospace"
            android:backgroundTint="#21262d"
            android:textColor="#8b949e" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progressTint="#39d353"
        android:progressBackgroundTint="#21262d"
        android:max="254"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[ 0 / 254 ]  hosts: 0 activos"
        android:textColor="#58a6ff"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:paddingBottom="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d1117" />

</LinearLayout>
